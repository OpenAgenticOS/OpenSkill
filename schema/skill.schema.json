{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/OpenAgenticOS/OpenSkill/blob/master/schema/skill.schema.json",
  "title": "OpenSkill Skill Schema",
  "description": "Schema for validating OpenSkill .skill.md YAML frontmatter (locale-per-file: *.zh.skill.md / *.en.skill.md)",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "category",
    "locale",
    "persona",
    "objective",
    "style",
    "tone",
    "audience",
    "output_format",
    "author"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+(/[a-z0-9_-]+){1,3}$",
      "description": "Globally unique skill ID in format: category/subcategory/skill_name"
    },
    "name": {
      "type": "string",
      "minLength": 3,
      "maxLength": 80,
      "description": "Human-readable skill name in this file's locale"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version"
    },
    "category": {
      "type": "string",
      "enum": [
        "c-suite/ceo",
        "c-suite/cto",
        "c-suite/cfo",
        "c-suite/coo",
        "c-suite/cmo",
        "c-suite/chro",
        "management/engineering-manager",
        "management/product-manager",
        "management/sales-manager",
        "management/hr-manager",
        "management/operations-manager",
        "management/finance-manager",
        "management/marketing-manager",
        "individual-contributor/software-engineer",
        "individual-contributor/data-analyst",
        "individual-contributor/data-scientist",
        "individual-contributor/designer",
        "individual-contributor/marketing",
        "individual-contributor/sales-rep",
        "individual-contributor/customer-success",
        "individual-contributor/legal",
        "individual-contributor/finance",
        "individual-contributor/devops",
        "individual-contributor/security",
        "cross-functional"
      ]
    },
    "locale": {
      "type": "string",
      "enum": ["zh", "en"],
      "description": "This file's language; pair with sibling .zh/.en.skill.md sharing the same id"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "maxItems": 8
    },
    "persona": {
      "type": "string",
      "minLength": 20,
      "description": "COSTAR: Who the AI acts as (single locale)"
    },
    "objective": {
      "type": "string",
      "minLength": 20,
      "description": "COSTAR: Core task to accomplish (single locale)"
    },
    "style": {
      "type": "string",
      "minLength": 10,
      "description": "COSTAR: Expected output style (single locale)"
    },
    "tone": {
      "type": "string",
      "minLength": 5,
      "description": "COSTAR: Expected tone (single locale)"
    },
    "audience": {
      "type": "string",
      "minLength": 5,
      "description": "COSTAR: Target audience (single locale)"
    },
    "output_format": {
      "type": "string",
      "minLength": 10,
      "description": "COSTAR: Expected output format (single locale)"
    },
    "translation_status": {
      "type": "string",
      "enum": [
        "complete",
        "partial",
        "pending"
      ],
      "description": "Translation completeness hint for maintainers"
    },
    "input_variables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "description"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "required": {
            "type": "boolean",
            "default": true
          },
          "example": {
            "type": "string"
          }
        }
      }
    },
    "compatible_models": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "language": {
      "type": "string",
      "enum": [
        "zh",
        "en",
        "zh-en"
      ],
      "description": "Optional hint; merged bundle uses zh-en when both locale files exist"
    },
    "difficulty": {
      "type": "string",
      "enum": [
        "beginner",
        "intermediate",
        "advanced"
      ]
    },
    "estimated_time": {
      "type": "string",
      "examples": [
        "2-5 min",
        "5-10 min",
        "10-30 min"
      ]
    },
    "author": {
      "type": "string",
      "description": "GitHub username of the contributor"
    },
    "created_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "quality_score": {
      "type": "number",
      "minimum": 1,
      "maximum": 5
    },
    "mcp_tool_name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "MCP-compatible tool name (snake_case)"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "reviewed", "promoted", "deprecated"],
      "description": "Lifecycle: draft (new) | reviewed | promoted (high bar) | deprecated"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "SHA-256 of markdown body (after frontmatter), for integrity checks"
    },
    "evaluation_rubric": {
      "type": "array",
      "description": "Optional scoring dimensions (PEEM-aligned baseline keys: prompt_clarity, prompt_fairness, accuracy, coherence, relevance, objectivity, response_clarity, conciseness; plus custom domain dimensions)",
      "minItems": 1,
      "maxItems": 16,
      "items": {
        "type": "object",
        "required": ["dimension"],
        "properties": {
          "dimension": {
            "type": "string",
            "minLength": 1,
            "description": "PEEM baseline or custom label, e.g. prompt_clarity or okr_structure"
          },
          "weight": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "criteria_5": {
            "type": "string"
          },
          "criteria_3": {
            "type": "string"
          },
          "criteria_1": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "evaluation_history": {
      "type": "array",
      "description": "Structured log of automated or manual evaluation runs",
      "items": {
        "type": "object",
        "required": ["date"],
        "properties": {
          "date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "model": {
            "type": "string"
          },
          "judge": {
            "type": "string"
          },
          "test_case": {
            "type": "string"
          },
          "overall_score": {
            "type": "number",
            "minimum": 1,
            "maximum": 5
          },
          "dimension_scores": {
            "type": "object",
            "additionalProperties": {
              "type": "number",
              "minimum": 1,
              "maximum": 5
            }
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "test_cases": {
      "type": "array",
      "description": "Optional structured test inputs and natural-language acceptance criteria",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "acceptance"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "input": {
            "type": "object",
            "additionalProperties": true
          },
          "acceptance": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "enhancers": {
      "type": "array",
      "description": "Optional declarative hints: tools or data sources that improve outcomes",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["data_source", "tool"]
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "protocol": {
            "type": "string",
            "enum": ["mcp", "api", "file", "any"]
          },
          "optional": {
            "type": "boolean"
          },
          "permissions": {
            "type": "object",
            "description": "Declarative capability hints for sandboxes (not enforced by OpenSkill)",
            "properties": {
              "network_outbound": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "filesystem": {
                "oneOf": [
                  {
                    "type": "string",
                    "enum": ["none"]
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                ]
              },
              "max_calls": {
                "type": "integer",
                "minimum": 0
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "composable_with": {
      "type": "array",
      "description": "Optional hints for chaining with other skills (declarative, not executable)",
      "items": {
        "type": "object",
        "required": ["skill_id", "relationship"],
        "properties": {
          "skill_id": {
            "type": "string",
            "minLength": 1
          },
          "relationship": {
            "type": "string",
            "enum": ["upstream", "downstream", "parallel"]
          },
          "data_mapping": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "evolution_history": {
      "type": "array",
      "description": "How and why this skill changed over versions",
      "items": {
        "type": "object",
        "required": ["version", "date", "method"],
        "properties": {
          "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
          },
          "date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "method": {
            "type": "string",
            "enum": [
              "human_authored",
              "evo_skills_refinement",
              "auto_skill_extraction",
              "community_pr"
            ]
          },
          "trigger": {
            "type": "string"
          },
          "changes": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "competence_profile": {
      "type": "object",
      "description": "Hints for orchestrators (SkillOrchestra-style routing)",
      "properties": {
        "task_types": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "domain_knowledge": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "input_complexity": {
          "type": "string",
          "enum": ["low", "low_to_medium", "medium", "high"]
        },
        "output_length": {
          "type": "string",
          "enum": ["short", "medium", "long"]
        },
        "reasoning_depth": {
          "type": "string",
          "enum": ["shallow", "moderate", "deep"]
        }
      },
      "additionalProperties": false
    },
    "model_benchmarks": {
      "type": "array",
      "description": "Aggregated scores from eval runs per model",
      "items": {
        "type": "object",
        "required": ["model", "overall_score", "sample_size", "date"],
        "properties": {
          "model": {
            "type": "string",
            "minLength": 1
          },
          "overall_score": {
            "type": "number",
            "minimum": 1,
            "maximum": 5
          },
          "sample_size": {
            "type": "integer",
            "minimum": 1
          },
          "date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "execution_profile": {
      "type": "object",
      "description": "Declarative cost/latency hints (not measured by OpenSkill)",
      "properties": {
        "avg_input_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "avg_output_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "avg_latency_ms": {
          "type": "number",
          "minimum": 0
        },
        "estimated_cost_usd": {
          "type": "number",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
