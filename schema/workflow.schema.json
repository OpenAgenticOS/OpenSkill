{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/OpenAgenticOS/OpenSkill/blob/master/schema/workflow.schema.json",
  "title": "OpenSkill Workflow Schema",
  "description": "Declarative multi-step workflow (*.zh.workflow.md / *.en.workflow.md)",
  "type": "object",
  "required": ["id", "name", "version", "locale", "steps", "author"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^workflow/[a-z0-9][a-z0-9_-]*$",
      "description": "Globally unique workflow id"
    },
    "name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 120
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "locale": {
      "type": "string",
      "enum": ["zh", "en"]
    },
    "trigger": {
      "type": "string"
    },
    "estimated_time": {
      "type": "string"
    },
    "difficulty": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced"]
    },
    "author": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": ["skill", "human", "tool", "condition"]
          },
          "description": {
            "type": "string"
          },
          "skill_id": {
            "type": "string"
          },
          "input_mapping": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "output": {
            "type": "string"
          },
          "condition": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
