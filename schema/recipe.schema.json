{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/OpenAgenticOS/OpenSkill/blob/master/schema/recipe.schema.json",
  "title": "OpenSkill Recipe Schema",
  "description": "Role/scenario guide (*.zh.recipe.md / *.en.recipe.md)",
  "type": "object",
  "required": ["id", "name", "version", "locale", "category", "roles", "skills_referenced", "author"],
  "properties": {
    "category": {
      "type": "string",
      "pattern": "^(c-suite|management|individual-contributor|cross-functional)(/[a-z0-9-]+)?$",
      "description": "Role hierarchy path (layer or layer/role), aligned with skills/"
    },
    "id": {
      "type": "string",
      "pattern": "^recipe/[a-z0-9][a-z0-9_-]*$",
      "description": "Globally unique recipe id"
    },
    "name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 120
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "locale": {
      "type": "string",
      "enum": ["zh", "en"]
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "skills_referenced": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "workflows_referenced": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "author": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    }
  },
  "additionalProperties": false
}
