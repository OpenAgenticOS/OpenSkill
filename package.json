{
  "name": "openskill",
  "version": "2.3.0",
  "description": "Enterprise AI skill library — validate skills, export openskill.json + locale bundles (zh/en)",
  "type": "module",
  "private": false,
  "scripts": {
    "validate": "node tools/validate.js",
    "export": "node tools/export_skills.js",
    "export:all": "node tools/export_skills.js --mcp-resources --progressive",
    "eval": "node tools/eval_runner.js",
    "evolve": "node tools/evolve_skill.js",
    "count": "node tools/count_skills.js",
    "build-index": "node tools/build_index.js",
    "fix-locale-tags": "node tools/fix_locale_tags_examples.js",
    "emit-manifest": "node tools/emit_manifest.cjs",
    "generate-skills": "node tools/generate_skills.js",
    "backfill-output-examples": "node tools/backfill_output_examples.js"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "gray-matter": "^4.0.3",
    "glob": "^13.0.6",
    "chalk": "^5.3.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "markdownlint-cli2": "^0.22.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "llm",
    "prompts",
    "skills",
    "enterprise",
    "ai",
    "openai",
    "claude",
    "gemini",
    "qwen"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenAgenticOS/OpenSkill.git"
  },
  "homepage": "https://github.com/OpenAgenticOS/OpenSkill#readme",
  "bugs": {
    "url": "https://github.com/OpenAgenticOS/OpenSkill/issues"
  }
}
