---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  locale?: string;
  canonical?: string;
}

const { title, description, locale = "en", canonical } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const siteUrl = (import.meta.env.SITE ?? "https://openagenticos.github.io") + base;
const canonicalUrl = canonical ?? Astro.url.href;

/** Build time = deploy time on GitHub Pages; use UTC so CI dates are stable. */
const buildAt = new Date();
const lastUpdatedLocale = locale === "zh" ? "zh-CN" : "en-US";
const lastUpdatedText = buildAt.toLocaleDateString(lastUpdatedLocale, {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "UTC",
});
const lastUpdatedLabel = locale === "zh" ? "站点更新" : "Last updated";
const utcSuffix = locale === "zh" ? "（UTC）" : " (UTC)";
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="AI skills, system prompts, enterprise AI, LLM prompts, ChatGPT, Claude, Gemini, COSTAR, prompt library, 企业大模型, 技能库, 提示词, OpenSkill" />
    <meta name="author" content="OpenAgenticOS" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href={`${base}/brain.svg`} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="OpenSkill" />
    <meta property="og:locale" content={locale === "zh" ? "zh_CN" : "en_US"} />
    <meta property="og:locale:alternate" content={locale === "zh" ? "en_US" : "zh_CN"} />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      name: "OpenSkill",
      url: siteUrl,
      description: "Enterprise AI Skill Library — 154+ role-specific system prompts",
      applicationCategory: "Productivity",
      operatingSystem: "Web",
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
      author: { "@type": "Organization", name: "OpenAgenticOS", url: "https://github.com/OpenAgenticOS" },
      license: "https://opensource.org/licenses/MIT",
      inLanguage: ["en", "zh"],
    })} />
  </head>
  <body class="bg-white text-gray-900 dark:bg-gray-950 dark:text-gray-100 min-h-screen flex flex-col">
    <!-- Deploy/build date: sticky under browser chrome, high contrast so it stays visible -->
    <div
      class="sticky top-0 z-50 flex h-10 shrink-0 items-center justify-center gap-2 border-b border-blue-800/30 bg-gradient-to-r from-blue-700 to-indigo-700 px-3 text-center text-xs font-semibold text-white shadow-md sm:text-sm"
      role="status"
      aria-live="polite"
    >
      <span class="inline-flex h-5 w-5 shrink-0 items-center justify-center rounded bg-white/15 text-[0.65rem] sm:text-xs" aria-hidden="true">📅</span>
      <span>
        <span class="opacity-90">{lastUpdatedLabel}</span>
        <span class="mx-1.5 opacity-60" aria-hidden="true">·</span>
        <span class="tabular-nums">{lastUpdatedText}</span>
        <span class="font-medium opacity-90">{utcSuffix}</span>
      </span>
    </div>
    <div class="flex min-h-0 flex-1 flex-col">
      <slot />
    </div>
  </body>
</html>
