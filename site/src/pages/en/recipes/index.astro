---
import Base from "../../../layouts/Base.astro";
import Header from "../../../components/Header.astro";
import RecipeBrowse from "../../../components/RecipeBrowse";
import { getRecipes } from "../../../lib/data";

const locale = "en";
const recipes = getRecipes();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base
  title="Recipes — OpenSkill"
  description="Role-specific scenario guides combining AI skills and workflows for enterprise use cases."
  locale="en"
>
  <Header locale="en" active="recipes" />
  <div class="flex flex-1" style="min-height: calc(100vh - 57px);">
    <RecipeBrowse client:load recipes={recipes} locale="en" base={base} />
  </div>
</Base>
