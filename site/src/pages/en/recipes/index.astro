---
import Base from "../../../layouts/Base.astro";
import Header from "../../../components/Header.astro";
import RecipeBrowse from "../../../components/RecipeBrowse";
import { getRecipes } from "../../../lib/data";
import { t } from "../../../lib/i18n";

const locale = "en";
const recipes = getRecipes();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base
  title="Recipes — OpenSkill"
  description="Role-specific scenario guides combining AI skills and workflows for enterprise use cases."
  locale="en"
>
  <Header locale="en" active="recipes" />
  <div class="mx-auto max-w-7xl px-4 pt-4">
    <p class="text-sm text-gray-600 dark:text-gray-400">
      {t("guideBannerRecipes", locale)}{" "}
      <a href={`${base}/${locale}/guide/`} class="font-medium text-blue-600 hover:underline dark:text-blue-400">{t("guideLink", locale)}</a>
    </p>
  </div>
  <div class="flex flex-1" style="min-height: calc(100vh - 57px);">
    <RecipeBrowse client:load recipes={recipes} locale="en" base={base} />
  </div>
</Base>
