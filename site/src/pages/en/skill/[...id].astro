---
import Base from "../../../layouts/Base.astro";
import Header from "../../../components/Header.astro";
import PromptComposer from "../../../components/PromptComposer";
import { getSkills, getSkill } from "../../../lib/data";
import { t } from "../../../lib/i18n";
import { label } from "../../../lib/categories";
import type { GetStaticPaths } from "astro";

export const getStaticPaths: GetStaticPaths = () => {
  return getSkills("en").map((s) => ({ params: { id: s.id } }));
};

const { id } = Astro.params;
const skill = getSkill("en", id as string)!;
const locale = "en";
const roleKey = skill.category.split("/")[1] ?? skill.category.split("/")[0];
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const difficultyColor: Record<string, string> = {
  beginner: "bg-green-100 text-green-700 dark:bg-green-900 dark:text-green-300",
  intermediate: "bg-yellow-100 text-yellow-700 dark:bg-yellow-900 dark:text-yellow-300",
  advanced: "bg-red-100 text-red-700 dark:bg-red-900 dark:text-red-300",
};

const statusColor: Record<string, string> = {
  draft: "bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400",
  reviewed: "bg-blue-100 text-blue-700 dark:bg-blue-900 dark:text-blue-300",
  promoted: "bg-green-100 text-green-700 dark:bg-green-900 dark:text-green-300",
  deprecated: "bg-red-100 text-red-600 dark:bg-red-900 dark:text-red-400",
};
---

<Base
  title={`${skill.name} — OpenSkill`}
  description={skill.objective}
  locale="en"
  canonical={`https://openagenticos.github.io/OpenSkill/en/skill/${skill.id}/`}
>
  <Header locale="en" active="skills" />
  <main class="mx-auto max-w-4xl px-4 py-6 md:py-10">
    <a href={`${base}/en/`} class="mb-4 inline-flex items-center gap-1 text-sm text-blue-600 hover:underline dark:text-blue-400">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="m15 19-7-7 7-7" /></svg>
      {t("backToList", locale)}
    </a>

    <!-- Hero -->
    <div class="mb-6">
      <h1 class="text-2xl font-bold md:text-3xl">{skill.name}</h1>
      <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">{skill.objective}</p>
      <div class="mt-3 flex flex-wrap items-center gap-2">
        <span class="rounded-md bg-blue-50 px-2 py-0.5 text-sm font-medium text-blue-700 dark:bg-blue-950 dark:text-blue-300">{label(roleKey, locale)}</span>
        <span class={`rounded-full px-2 py-0.5 text-xs font-medium ${difficultyColor[skill.difficulty] ?? ""}`}>{skill.difficulty}</span>
        {skill.status && (
          <span class={`rounded-full px-2 py-0.5 text-xs font-medium ${statusColor[skill.status] ?? statusColor.draft}`}>{skill.status}</span>
        )}
        <span class="text-xs text-gray-400">{skill.estimated_time}</span>
      </div>
      <div class="mt-3 flex flex-wrap gap-1.5">
        {skill.tags.map((tag) => (
          <span class="rounded-md bg-gray-100 px-2 py-0.5 text-xs text-gray-600 dark:bg-gray-800 dark:text-gray-400">{tag}</span>
        ))}
      </div>
    </div>

    <!-- COSTAR cards -->
    <div class="mb-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {[
        [t("persona", locale), skill.persona],
        [t("style", locale), skill.style],
        [t("tone", locale), skill.tone],
        [t("audience", locale), skill.audience],
        [t("outputFormat", locale), skill.output_format],
      ].map(([lbl, val]) => (
        <div class="rounded-lg border border-gray-200 p-3 dark:border-gray-800">
          <span class="mb-1 block text-[11px] font-semibold uppercase tracking-wide text-gray-400">{lbl}</span>
          <p class="text-sm leading-snug">{val}</p>
        </div>
      ))}
    </div>

    <!-- Evaluation Rubric -->
    {skill.evaluation_rubric && skill.evaluation_rubric.length > 0 && (
      <section class="mb-6">
        <h2 class="mb-3 text-lg font-semibold">{t("evaluationRubric", locale)}</h2>
        <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-gray-800">
          <table class="w-full text-sm">
            <thead class="bg-gray-50 dark:bg-gray-900">
              <tr>
                <th class="px-3 py-2 text-left font-medium text-gray-500">{t("dimension", locale)}</th>
                <th class="px-3 py-2 text-center font-medium text-gray-500">{t("weight", locale)}</th>
                <th class="px-3 py-2 text-left font-medium text-gray-500">{t("criteria5", locale)}</th>
                <th class="px-3 py-2 text-left font-medium text-gray-500">{t("criteria3", locale)}</th>
                <th class="px-3 py-2 text-left font-medium text-gray-500">{t("criteria1", locale)}</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
              {skill.evaluation_rubric.map((r) => (
                <tr>
                  <td class="px-3 py-2 font-medium">{r.dimension}</td>
                  <td class="px-3 py-2 text-center">{(r.weight * 100).toFixed(0)}%</td>
                  <td class="px-3 py-2 text-gray-600 dark:text-gray-400">{r.criteria_5}</td>
                  <td class="px-3 py-2 text-gray-600 dark:text-gray-400">{r.criteria_3}</td>
                  <td class="px-3 py-2 text-gray-600 dark:text-gray-400">{r.criteria_1}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )}

    <!-- Composable Skills -->
    {skill.composable_with && skill.composable_with.length > 0 && (
      <section class="mb-6">
        <h2 class="mb-3 text-lg font-semibold">{t("composableWith", locale)}</h2>
        <div class="space-y-2">
          {skill.composable_with.map((c) => (
            <div class="rounded-lg border border-gray-200 p-3 dark:border-gray-800">
              <div class="flex items-center gap-2 mb-1">
                <a href={`${base}/${locale}/skill/${c.skill_id}/`} class="text-sm font-medium text-blue-600 hover:underline dark:text-blue-400">{c.skill_id}</a>
                <span class={`rounded-full px-2 py-0.5 text-xs font-medium ${c.relationship === "upstream" ? "bg-amber-100 text-amber-700 dark:bg-amber-900 dark:text-amber-300" : c.relationship === "downstream" ? "bg-emerald-100 text-emerald-700 dark:bg-emerald-900 dark:text-emerald-300" : "bg-purple-100 text-purple-700 dark:bg-purple-900 dark:text-purple-300"}`}>{t(c.relationship as any, locale)}</span>
              </div>
              <p class="text-xs text-gray-500 dark:text-gray-400">{c.data_mapping}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Enhancers -->
    {skill.enhancers && skill.enhancers.length > 0 && (
      <section class="mb-6">
        <h2 class="mb-3 text-lg font-semibold">{t("enhancers", locale)}</h2>
        <div class="space-y-2">
          {skill.enhancers.map((e) => (
            <div class="rounded-lg border border-gray-200 p-3 dark:border-gray-800">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-sm font-medium">{e.name}</span>
                <span class="rounded-full bg-indigo-100 px-2 py-0.5 text-xs font-medium text-indigo-700 dark:bg-indigo-900 dark:text-indigo-300">{e.type}</span>
                {e.optional && <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs text-gray-500 dark:bg-gray-800">optional</span>}
              </div>
              <p class="text-xs text-gray-500 dark:text-gray-400">{e.description}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Prompt Composer -->
    <PromptComposer
      client:load
      systemPrompt={skill.system_prompt}
      userTemplate={skill.user_prompt_template}
      variables={skill.input_variables}
      locale="en"
    />

    <!-- Output Example -->
    {skill.output_example && (
      <section class="mt-6">
        <h2 class="mb-3 text-lg font-semibold">{t("outputExample", locale)}</h2>
        <div class="rounded-xl border border-gray-200 bg-gray-50 p-4 dark:border-gray-800 dark:bg-gray-900">
          <pre class="whitespace-pre-wrap text-sm leading-relaxed">{skill.output_example}</pre>
        </div>
      </section>
    )}

    <!-- Related Skills -->
    {skill.related_skills.length > 0 && (
      <section class="mt-6">
        <h2 class="mb-3 text-lg font-semibold">{t("relatedSkills", locale)}</h2>
        <div class="flex flex-wrap gap-2">
          {skill.related_skills.map((rs) => (
            <a href={`${base}/${locale}/skill/${rs.id}/`} class="inline-flex items-center gap-1.5 rounded-lg border border-gray-200 px-3 py-1.5 text-sm transition hover:border-blue-300 hover:bg-blue-50 dark:border-gray-700 dark:hover:border-blue-700 dark:hover:bg-blue-950">
              <svg class="h-3.5 w-3.5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M13.828 10.172a4 4 0 0 0-5.656 0l-4 4a4 4 0 1 0 5.656 5.656l1.102-1.101" /><path stroke-linecap="round" stroke-width="2" d="M10.172 13.828a4 4 0 0 0 5.656 0l4-4a4 4 0 0 0-5.656-5.656l-1.1 1.1" /></svg>
              {rs.name}
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Compatible Models -->
    {skill.compatible_models.length > 0 && (
      <section class="mt-6 pb-8">
        <h2 class="mb-2 text-sm font-semibold text-gray-500">{t("compatibleModels", locale)}</h2>
        <div class="flex flex-wrap gap-1.5">
          {skill.compatible_models.map((m) => (
            <span class="rounded-md bg-gray-100 px-2 py-0.5 text-xs dark:bg-gray-800">{m}</span>
          ))}
        </div>
      </section>
    )}
  </main>
</Base>
