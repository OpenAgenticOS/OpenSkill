---
import Base from "../../../layouts/Base.astro";
import Header from "../../../components/Header.astro";
import WorkflowBrowse from "../../../components/WorkflowBrowse";
import { getWorkflows } from "../../../lib/data";
import { t } from "../../../lib/i18n";

const locale = "en";
const workflows = getWorkflows();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base
  title="Workflows — OpenSkill"
  description="Multi-step orchestration templates that chain AI skills together for end-to-end enterprise processes."
  locale="en"
>
  <Header locale="en" active="workflows" />
  <div class="mx-auto max-w-7xl px-4 pt-4">
    <p class="text-sm text-gray-600 dark:text-gray-400">
      {t("guideBannerWorkflows", locale)}{" "}
      <a href={`${base}/${locale}/guide/`} class="font-medium text-blue-600 hover:underline dark:text-blue-400">{t("guideLink", locale)}</a>
    </p>
  </div>
  <div class="flex flex-1" style="min-height: calc(100vh - 57px);">
    <WorkflowBrowse client:load workflows={workflows} locale="en" base={base} />
  </div>
</Base>
