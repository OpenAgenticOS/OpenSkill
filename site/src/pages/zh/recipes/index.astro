---
import Base from "../../../layouts/Base.astro";
import Header from "../../../components/Header.astro";
import RecipeBrowse from "../../../components/RecipeBrowse";
import { getRecipes } from "../../../lib/data";

const locale = "zh";
const recipes = getRecipes();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base
  title="场景指南 — OpenSkill"
  description="面向角色的场景指南，组合技能与工作流，适用于企业场景。"
  locale="zh"
>
  <Header locale="zh" active="recipes" />
  <div class="flex flex-1" style="min-height: calc(100vh - 57px);">
    <RecipeBrowse client:load recipes={recipes} locale="zh" base={base} />
  </div>
</Base>
