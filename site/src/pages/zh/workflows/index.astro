---
import Base from "../../../layouts/Base.astro";
import Header from "../../../components/Header.astro";
import WorkflowBrowse from "../../../components/WorkflowBrowse";
import { getWorkflows } from "../../../lib/data";
import { t } from "../../../lib/i18n";

const locale = "zh";
const workflows = getWorkflows();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base
  title="工作流 — OpenSkill"
  description="多步编排模板，将 AI 技能串联为端到端企业流程。"
  locale="zh"
>
  <Header locale="zh" active="workflows" />
  <div class="mx-auto max-w-7xl px-4 pt-4">
    <p class="text-sm text-gray-600 dark:text-gray-400">
      {t("guideBannerWorkflows", locale)}{" "}
      <a href={`${base}/${locale}/guide/`} class="font-medium text-blue-600 hover:underline dark:text-blue-400">{t("guideLink", locale)}</a>
    </p>
  </div>
  <div class="flex flex-1" style="min-height: calc(100vh - 57px);">
    <WorkflowBrowse client:load workflows={workflows} locale="zh" base={base} />
  </div>
</Base>
