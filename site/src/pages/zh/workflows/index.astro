---
import Base from "../../../layouts/Base.astro";
import Header from "../../../components/Header.astro";
import { getWorkflows } from "../../../lib/data";
import { t } from "../../../lib/i18n";

const locale = "zh";
const workflows = getWorkflows();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base
  title="工作流 — OpenSkill"
  description="多步编排模板，将 AI 技能串联为端到端企业流程。"
  locale="zh"
>
  <Header locale="zh" active="workflows" />
  <main class="mx-auto max-w-5xl px-4 py-8 md:py-12">
    <div class="mb-8 text-center">
      <h1 class="text-3xl font-bold">{t("workflows", locale)}</h1>
      <p class="mt-2 text-gray-500 dark:text-gray-400">{t("workflowsSubtitle", locale)}</p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      {workflows.map((wf) => {
        const name = wf.name_zh;
        const trigger = wf.trigger_zh ?? "";
        const steps = wf.steps_zh;
        const href = `${base}/${locale}/workflow/${wf.id.replace("workflow/", "")}/`;
        return (
          <a href={href} class="group flex flex-col rounded-xl border border-gray-200 bg-white p-5 shadow-sm transition hover:border-blue-300 hover:shadow-md dark:border-gray-800 dark:bg-gray-900 dark:hover:border-blue-700">
            <h3 class="text-base font-semibold group-hover:text-blue-600 dark:group-hover:text-blue-400">{name}</h3>
            {trigger && <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">{trigger}</p>}
            <div class="mt-3 flex items-center gap-3 text-xs text-gray-400">
              <span class="rounded-full bg-gray-100 px-2 py-0.5 dark:bg-gray-800">{wf.difficulty}</span>
              <span>{wf.estimated_time}</span>
              <span>{steps.length} {t("steps", locale)}</span>
            </div>
            <div class="mt-3 flex flex-wrap gap-1">
              {steps.filter((s) => s.type === "skill").map((s) => (
                <span class="rounded bg-blue-50 px-1.5 py-0.5 text-xs text-blue-700 dark:bg-blue-950 dark:text-blue-300">{s.skill_id}</span>
              ))}
            </div>
          </a>
        );
      })}
    </div>
  </main>
</Base>
