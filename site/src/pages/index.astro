---
import Base from "../layouts/Base.astro";
---

<Base
  title="OpenSkill — Enterprise AI Skill Library"
  description="Browse 140+ enterprise AI skills by role. One-click copy system prompts for ChatGPT, Claude, Gemini and more."
>
  <script is:inline define:vars={{ basePath: import.meta.env.BASE_URL.replace(/\/$/, "") }}>
    var lang = (navigator.language || "en").toLowerCase();
    var loc = lang.startsWith("zh") ? "zh" : "en";
    window.location.replace(basePath + "/" + loc + "/");
  </script>
  <noscript>
    <meta http-equiv="refresh" content={`0;url=${import.meta.env.BASE_URL.replace(/\/$/, "")}/en/`} />
  </noscript>
  <main class="flex items-center justify-center min-h-screen">
    <p class="text-gray-500">Redirecting...</p>
  </main>
</Base>
